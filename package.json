{
  "name": "exlege",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "pnpm --filter @exlege/db generate",
    "db:migrate": "pnpm --filter @exlege/db migrate:dev",
    "db:seed": "pnpm --filter @exlege/db seed",
    "db:studio": "pnpm --filter @exlege/db studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.8.4",
    "turbo": "^2.9.14",
    "typescript": "^5.9.3"
  }
}
