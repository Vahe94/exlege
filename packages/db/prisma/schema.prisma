// ExLege schema — RULE: every domain table carries tenantId, even while single-tenant.
// Localized text fields are Json: { "hy": "...", "en": "..." }

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- tenancy & auth ----------

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique // subdomain-safe identifier
  name      String
  /// branding: { logoKey, primaryColor, ... }
  theme     Json     @default("{}")
  locales   String[] @default(["hy"])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  cases       Case[]
  tasks       Task[]
  reminders   Reminder[]
  documents   Document[]
  posts       Post[]
  leads       Lead[]
  notifications Notification[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  locale       String   @default("hy")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships    Membership[]
  assignedTasks  Task[]         @relation("TaskAssignee")
  createdTasks   Task[]         @relation("TaskCreator")
  createdCases   Case[]
  documents      Document[]
  posts          Post[]
  notifications  Notification[]
  refreshTokens  RefreshToken[]
}

enum Role {
  OWNER
  ADMIN
  ATTORNEY
  ASSISTANT
}

model Membership {
  id       String @id @default(cuid())
  tenantId String
  userId   String
  role     Role   @default(ASSISTANT)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------- work organization ----------

enum CaseStatus {
  OPEN
  ON_HOLD
  CLOSED
}

model Case {
  id          String     @id @default(cuid())
  tenantId    String
  title       String
  number      String? // court/internal case number
  clientName  String?
  description String?
  status      CaseStatus @default(OPEN)
  createdById String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User       @relation(fields: [createdById], references: [id])
  tasks     Task[]
  documents Document[]

  @@index([tenantId, status])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id          String       @id @default(cuid())
  tenantId    String
  caseId      String?
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueAt       DateTime?
  assigneeId  String?
  createdById String
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  case      Case?      @relation(fields: [caseId], references: [id], onDelete: SetNull)
  assignee  User?      @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy User       @relation("TaskCreator", fields: [createdById], references: [id])
  reminders Reminder[]

  @@index([tenantId, status, dueAt])
  @@index([tenantId, assigneeId])
}

enum ReminderChannel {
  IN_APP
  EMAIL
  PUSH
}

model Reminder {
  id       String          @id @default(cuid())
  tenantId String
  taskId   String
  remindAt DateTime
  channel  ReminderChannel @default(IN_APP)
  sentAt   DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([sentAt, remindAt]) // scheduler scans unsent due reminders
  @@index([tenantId])
}

model Notification {
  id        String    @id @default(cuid())
  tenantId  String
  userId    String
  type      String // e.g. "task.due", "task.assigned"
  title     String
  body      String?
  /// arbitrary payload, e.g. { taskId }
  data      Json      @default("{}")
  readAt    DateTime?
  createdAt DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, readAt])
}

// ---------- documents ----------

model Document {
  id           String   @id @default(cuid())
  tenantId     String
  caseId       String?
  name         String
  mimeType     String
  sizeBytes    Int
  /// StorageProvider key (local path now, S3 key later) — never a raw URL
  storageKey   String   @unique
  uploadedById String
  createdAt    DateTime @default(now())

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  case       Case?  @relation(fields: [caseId], references: [id], onDelete: SetNull)
  uploadedBy User   @relation(fields: [uploadedById], references: [id])

  @@index([tenantId, caseId])
}

// ---------- website content ----------

enum PostType {
  NEWS
  CASE_WIN
  VIDEO
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

model Post {
  id            String     @id @default(cuid())
  tenantId      String
  type          PostType
  slug          String
  /// localized: { "hy": "..." }
  title         Json
  /// localized excerpt
  excerpt       Json?
  /// Tiptap JSON per locale: { "hy": {...} }
  content       Json?
  videoUrl      String?
  coverImageKey String?
  status        PostStatus @default(DRAFT)
  publishedAt   DateTime?
  authorId      String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])

  @@unique([tenantId, slug])
  @@index([tenantId, type, status, publishedAt])
}

// ---------- leads (public site forms) ----------

enum LeadStatus {
  NEW
  CONTACTED
  CLOSED
}

model Lead {
  id        String     @id @default(cuid())
  tenantId  String
  name      String
  phone     String
  email     String?
  message   String?
  source    String     @default("contact_form")
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, createdAt])
}
