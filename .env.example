# Database (docker-compose exposes Postgres on 5433)
DATABASE_URL="postgresql://exlege:exlege_dev@localhost:5433/exlege?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# API
API_PORT=4000
JWT_SECRET="change-me-in-production"
JWT_ACCESS_TTL="15m"

# Seed (dev only)
SEED_OWNER_EMAIL="admin@exlege.local"
SEED_OWNER_PASSWORD="ChangeMe123!"

# Local file storage (V1 StorageProvider=local)
STORAGE_DRIVER="local"
STORAGE_LOCAL_PATH="./storage/uploads"

# Public endpoints tenant resolution (V1 single-tenant)
DEFAULT_TENANT_SLUG="exlege"

# Web / Admin
NEXT_PUBLIC_API_URL="http://localhost:4000"
