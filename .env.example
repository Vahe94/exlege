# Database (docker-compose exposes Postgres on 5433)
DATABASE_URL="postgresql://exlege:exlege_dev@localhost:5433/exlege?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# API
API_PORT=4000
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-too"

# Local file storage (V1 StorageProvider=local)
STORAGE_DRIVER="local"
STORAGE_LOCAL_PATH="./storage/uploads"

# Web / Admin
NEXT_PUBLIC_API_URL="http://localhost:4000"
